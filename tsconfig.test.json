{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/test",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "tests/**/*",
    "src/main/**/*",
    "src/preload/**/*.d.ts",
    "src/renderer/**/*",
    "src/shared/**/*"
  ]
}
